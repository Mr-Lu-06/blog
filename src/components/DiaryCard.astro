---
import { formatDate } from '../utils/date';

export interface Props {
  title: string;
  date: Date;
  slug: string;
  tags?: string[];
  mood?: string;
  weather?: string;
  featured_image?: string;
  excerpt?: string;
}

const { title, date, slug, tags = [], mood, weather, featured_image, excerpt } = Astro.props;

// Random card rotation for magazine feel (subtle)
const rotation = ((slug?.length || 0) % 5 - 2) * 0.4;
---

<article
  class="diary-card"
  style={`--card-rotate: ${rotation}deg;`}
>
  <a href={`/diary/${slug}`} class="diary-card-link">
    {
      featured_image && (
        <div class="diary-card-image">
          <img src={featured_image} alt={title} loading="lazy" />
          <div class="image-overlay">
                      </div>
        </div>
      )
    }
    <div class="diary-card-body">
      <div class="diary-card-meta">
        <time class="diary-date" datetime={date.toISOString()}>
          {formatDate(date.toISOString())}
        </time>
        <div class="diary-badges">
          {mood && <span class="diary-badge mood">{mood}</span>}
          {weather && <span class="diary-badge weather">{weather}</span>}
        </div>
      </div>
      <h2 class="diary-card-title">{title}</h2>
      {excerpt && <p class="diary-card-excerpt">{excerpt}</p>}
      {
        tags.length > 0 && (
          <div class="diary-card-tags">
            {tags.map(tag => <span class="diary-tag">{tag}</span>)}
          </div>
        )
      }
    </div>
  </a>
</article>

<style>
  .diary-card {
    background: var(--gradient-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: rotate(var(--card-rotate));
  }

  .diary-card:hover {
    transform: rotate(0deg) translateY(-8px) scale(1.02);
    box-shadow: var(--shadow-float);
    border-color: var(--accent);
  }

  .diary-card-link {
    display: block;
    color: inherit !important;
    text-decoration: none;
  }

  .diary-card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    position: relative;
  }

  .diary-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.5s ease;
  }

  .diary-card:hover .diary-card-image img {
    transform: scale(1.08);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  .overlay-icon {
    font-size: 2rem;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
  }

  .diary-card:hover .image-overlay {
    background: rgba(0,0,0,0.15);
  }

  .diary-card:hover .overlay-icon {
    opacity: 1;
    transform: translateY(0);
  }

  .diary-card-body {
    padding: 20px;
  }

  .diary-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 10px;
  }

  .diary-date {
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
  }

  .diary-badges {
    display: flex;
    gap: 6px;
  }

  .diary-badge {
    font-size: 0.75rem;
    padding: 3px 10px;
    border-radius: 12px;
    font-weight: 600;
  }

  .diary-badge.mood {
    background: var(--accent-light);
    color: var(--tag-text);
  }

  .diary-badge.weather {
    background: var(--accent2-light);
    color: var(--tag-text2);
  }

  .diary-card-title {
    font-size: 1.15rem;
    font-weight: 800;
    margin: 0 0 8px;
    line-height: 1.4;
    color: var(--text-primary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.3s;
  }

  .diary-card:hover .diary-card-title {
    color: var(--accent);
  }

  .diary-card-excerpt {
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.65;
    margin: 0 0 14px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .diary-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .diary-tag {
    font-size: 0.72rem;
    padding: 3px 10px;
    border-radius: 8px;
    background: var(--tag-bg);
    color: var(--tag-text);
    font-weight: 600;
    transition: all 0.2s;
  }

  .diary-card:hover .diary-tag {
    background: var(--accent-soft);
  }

  @media (max-width: 768px) {
    .diary-card-image {
      height: 160px;
    }
  }
</style>
