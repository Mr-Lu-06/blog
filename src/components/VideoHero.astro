---
// 全屏视频封面 — 铺满整个视口
// 视频文件放到 public/video/hero.mp4

export interface Props {
  src?: string;
}

const { src } = Astro.props;
const videoSrc = src || '/video/hero.mp4';
---

<div class="video-hero">
  <video
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    class="video-hero-bg"
  >
    <source src={videoSrc} type="video/mp4" />
  </video>
</div>

<style>
  .video-hero {
    position: relative;
    width: 100vw;
    height: 520px;
    margin: 0;
    overflow: hidden;
    margin-left: calc(-50vw + 50%);
    border-radius: 0;
  }

  .video-hero-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  @media (max-width: 768px) {
    .video-hero { height: 340px; }
  }

  @media (max-width: 480px) {
    .video-hero { height: 240px; }
  }
</style>
