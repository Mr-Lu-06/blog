---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  showNavbar?: boolean;
  showFooter?: boolean;
  showMusic?: boolean;
}

const { title, description, showNavbar = true, showFooter = true, showMusic = true } = Astro.props;
const fullTitle = title ? `${title} — 我的blog` : '我的blog — 记录生活';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || '个人博客，记录日常生活的点点滴滴'} />
    <meta name="keywords" content="个人博客,日记,生活记录,相册,日常" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description || '个人博客，记录日常生活的点点滴滴'} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
  </head>
  <body>
    {showNavbar && <Navbar />}
    <main>
      <slot />
    </main>
    {showFooter && <Footer />}
    {showMusic && <MusicPlayer />}
  </body>
</html>
