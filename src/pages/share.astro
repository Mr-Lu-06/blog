---
import { getCollection } from 'astro:content';
import { sortByDate } from '../utils/date';
import BaseLayout from '../layouts/BaseLayout.astro';

const diaries = await getCollection('diary');
const galleries = await getCollection('gallery');
const sorted = sortByDate(diaries);
const diaryCount = diaries.length;
const galleryCount = galleries.length;
---

<BaseLayout title="发现" description="分享生活的点滴">
  <div class="app-wrapper">
    <!-- ===== Header ===== -->
    <header class="app-header">
      <div class="header-top">
        <h1 class="header-title">TA的日记</h1>
        <a href="/admin/" class="header-add-btn" title="写日记">+</a>
      </div>
      <div class="header-stats">
        <span>{diaryCount}篇日记 · {galleryCount}篇图片</span>
        <button class="filter-btn" id="filter-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
    </header>

    <!-- ===== Content ===== -->
    <main class="app-content" id="app-content">
      {sorted.length > 0 ? (
        <div class="diary-feed">
          {sorted.map((entry) => (
            <a href={`/diary/${entry.id}`} class="feed-item">
              <div class="feed-item-header">
                <div class="feed-avatar">
                  <span class="feed-avatar-text">{entry.data.mood || '记'}</span>
                </div>
                <div class="feed-meta">
                  <span class="feed-date">{entry.data.date.toISOString().split('T')[0]}</span>
                  {entry.data.mood && <span class="feed-mood">{entry.data.mood}</span>}
                </div>
              </div>
              <h3 class="feed-title">{entry.data.title}</h3>
              <p class="feed-excerpt">
                {entry.rendered?.html?.replace(/<[^>]*>/g, '').substring(0, 80).trim() + '...'}
              </p>
              {
                entry.data.tags && entry.data.tags.length > 0 && (
                  <div class="feed-tags">
                    {entry.data.tags.slice(0, 3).map(tag => <span class="feed-tag">{tag}</span>)}
                  </div>
                )
              }
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-feed">
          <div class="empty-illustration">
            <div class="empty-icon-circle"></div>
            <div class="empty-lines">
              <div class="empty-line"></div>
              <div class="empty-line short"></div>
            </div>
          </div>
          <p class="empty-text">还没有日记</p>
          <a href="/admin/" class="empty-link">去写第一篇</a>
        </div>
      )}
    </main>

    <!-- ===== Bottom Tab Bar ===== -->
    <nav class="tab-bar">
      <a href="/share" class="tab-item active" aria-label="日记">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
        <span>日记</span>
      </a>
      <a href="/" class="tab-item" aria-label="关注">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span>关注</span>
      </a>
      <a href="/admin/" class="tab-item tab-add" aria-label="发布">
        <div class="tab-add-btn">+</div>
      </a>
      <a href="/gallery" class="tab-item" aria-label="发现">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M10 8l6 4-6 4V8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
        <span>发现</span>
      </a>
      <a href="/" class="tab-item" aria-label="我的">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M7 18.5c.8-2.7 3.1-4.5 5-4.5s4.2 1.8 5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span>我的</span>
      </a>
    </nav>
  </div>
</BaseLayout>

<style>
  .app-wrapper {
    max-width: 480px;
    margin: 0 auto;
    min-height: 100vh;
    background: var(--bg-primary);
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border-color);
    border-right: 1px solid var(--border-color);
    position: relative;
  }

  /* ===== Header ===== */
  .app-header {
    padding: 16px 20px 12px;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .header-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0;
  }

  .header-add-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 300;
    text-decoration: none;
    transition: all 0.2s;
    line-height: 1;
  }

  .header-add-btn:hover {
    background: var(--accent-hover);
    transform: scale(1.08);
  }

  .header-stats {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .filter-btn {
    background: none;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 4px 8px;
    cursor: pointer;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
  }

  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ===== Content ===== */
  .app-content {
    flex: 1;
    padding: 12px 16px;
    padding-bottom: 80px;
    overflow-y: auto;
  }

  .diary-feed {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feed-item {
    display: block;
    padding: 16px;
    background: var(--bg-card);
    border-radius: 12px;
    border: 1px solid var(--border-color);
    color: inherit;
    text-decoration: none;
    transition: all 0.2s;
  }

  .feed-item:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-sm);
  }

  .feed-item-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .feed-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--gradient-warm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .feed-avatar-text {
    font-size: 0.8rem;
    color: #fff;
    font-weight: 600;
  }

  .feed-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .feed-date {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .feed-mood {
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 8px;
    background: var(--accent-light);
    color: var(--accent);
    font-weight: 500;
  }

  .feed-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 6px;
    color: var(--text-primary);
  }

  .feed-excerpt {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin: 0 0 10px;
    line-height: 1.55;
  }

  .feed-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .feed-tag {
    font-size: 0.72rem;
    padding: 2px 8px;
    border-radius: 6px;
    background: var(--tag-bg);
    color: var(--tag-text);
  }

  /* ===== Empty State ===== */
  .empty-feed {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 20px;
    text-align: center;
  }

  .empty-illustration {
    width: 120px;
    height: 120px;
    margin-bottom: 20px;
    position: relative;
  }

  .empty-icon-circle {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: var(--gradient-warm);
    opacity: 0.15;
    margin: 0 auto;
    position: relative;
    top: 10px;
  }

  .empty-lines {
    position: absolute;
    top: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .empty-line {
    width: 40px;
    height: 4px;
    border-radius: 2px;
    background: var(--accent);
    opacity: 0.3;
  }

  .empty-line.short {
    width: 24px;
    opacity: 0.2;
  }

  .empty-text {
    font-size: 1rem;
    color: var(--text-secondary);
    margin: 0 0 16px;
  }

  .empty-link {
    padding: 10px 28px;
    border-radius: 20px;
    background: var(--accent);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .empty-link:hover {
    background: var(--accent-hover);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(240, 132, 108, 0.3);
  }

  /* ===== Tab Bar ===== */
  .tab-bar {
    display: flex;
    align-items: flex-start;
    justify-content: space-around;
    padding: 8px 12px 12px;
    background: var(--bg-card);
    border-top: 1px solid var(--border-color);
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 480px;
    z-index: 20;
    padding-bottom: max(12px, env(safe-area-inset-bottom));
  }

  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 6px 12px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.7rem;
    transition: color 0.2s;
    border-radius: 8px;
  }

  .tab-item:hover {
    color: var(--text-secondary);
  }

  .tab-item.active {
    color: var(--accent);
  }

  .tab-item svg {
    width: 22px;
    height: 22px;
  }

  .tab-add {
    position: relative;
  }

  .tab-add-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--gradient-warm);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    font-weight: 300;
    margin-top: -20px;
    box-shadow: 0 4px 16px rgba(240, 132, 108, 0.35);
    transition: all 0.3s;
    line-height: 1;
  }

  .tab-add:hover .tab-add-btn {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(240, 132, 108, 0.45);
  }

  .tab-add span { display: none; }

  @media (max-width: 480px) {
    .app-wrapper {
      border-left: none;
      border-right: none;
    }
    .app-header { padding: 12px 16px 10px; }
  }
</style>
