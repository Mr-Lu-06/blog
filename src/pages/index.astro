---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="欢迎" showNavbar={false} showFooter={false} showMusic={false}>
  <div class="splash" id="splash">
    <!-- 阶段1：首页动画（手动播放） -->
    <video
      id="video-shouye"
      class="splash-video active"
      src="/video/shouye.mp4"
      muted
      playsinline
      preload="auto"
    ></video>

    <!-- 阶段2：转场动画（自动播放，初始隐藏） -->
    <video
      id="video-zhuanchang"
      class="splash-video"
      src="/video/zhuanchang.mp4"
      muted
      playsinline
      preload="auto"
    ></video>

    <!-- 《你的名字》蒂亚马特彗星 -->
    <div class="comet-wrapper" id="glow-dot">
      <!-- 环绕小彗星 1（白粉色） -->
      <div class="orbit-ring orbit-1">
        <div class="mini-comet">
          <div class="mini-head"></div>
          <div class="mini-tail"></div>
        </div>
      </div>
      <!-- 环绕小彗星 2（白粉色） -->
      <div class="orbit-ring orbit-2">
        <div class="mini-comet">
          <div class="mini-head"></div>
          <div class="mini-tail"></div>
        </div>
      </div>
      <!-- 主体彗星（天蓝色） -->
      <div class="tiamat-comet">
        <!-- 彗核 -->
        <div class="nucleus">
          <div class="core-dot"></div>
          <div class="glow-ring ring-a"></div>
          <div class="glow-ring ring-b"></div>
          <div class="glow-ring ring-c"></div>
        </div>
        <!-- 离子尾（天蓝，细长明亮） -->
        <div class="ion-tail">
          <div class="ion-tail-core"></div>
          <div class="ion-tail-glow"></div>
        </div>
        <!-- 尘埃尾（浅天蓝，较宽弥散） -->
        <div class="dust-tail">
          <div class="dust-tail-core"></div>
          <div class="dust-tail-glow"></div>
        </div>
        <!-- 碎片粒子 -->
        <div class="fragments">
          <div class="frag f1"></div>
          <div class="frag f2"></div>
          <div class="frag f3"></div>
          <div class="frag f4"></div>
          <div class="frag f5"></div>
          <div class="frag f6"></div>
          <div class="frag f7"></div>
          <div class="frag f8"></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const shouye = document.getElementById('video-shouye');
  const zhuanchang = document.getElementById('video-zhuanchang');
  const glowDot = document.getElementById('glow-dot');

  const startFlow = () => {
    glowDot.classList.add('hidden');
    shouye.playbackRate = 1.5;
    shouye.play().catch(() => {
      // 播放失败，直接跳转阶段2
      shouye.classList.remove('active');
      zhuanchang.classList.add('active');
      zhuanchang.play().catch(() => {
        document.querySelector('.splash').style.opacity = '0';
        setTimeout(() => window.location.href = '/diary', 400);
      });
    });
  };

  // 点击闪光点开始
  glowDot.addEventListener('click', startFlow);

  // 阶段1 → 阶段2
  shouye.addEventListener('ended', () => {
    shouye.classList.remove('active');
    zhuanchang.classList.add('active');
    zhuanchang.play().catch(() => {});
  });

  // 阶段2 → 跳转
  zhuanchang.addEventListener('ended', () => {
    document.querySelector('.splash').style.opacity = '0';
    setTimeout(() => window.location.href = '/diary', 400);
  });

  zhuanchang.addEventListener('error', () => {
    window.location.href = '/diary';
  });
</script>

<style>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    overflow: hidden;
    transition: opacity 0.5s ease;
  }

  .splash-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .splash-video.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ===== 蒂亚马特彗星（君の名は） ===== */
  .comet-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    cursor: pointer;
    transition: opacity 0.5s ease;
  }

  .comet-wrapper.hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* ====== 环绕小彗星（白粉色） ====== */
  .orbit-ring {
    position: absolute;
    top: 50%; left: 50%;
    border-radius: 50%;
    pointer-events: none;
  }

  .orbit-1 {
    width: 260px;
    height: 260px;
    margin: -130px 0 0 -130px;
    animation: orbit-spin 6s linear infinite;
  }

  .orbit-2 {
    width: 340px;
    height: 340px;
    margin: -170px 0 0 -170px;
    animation: orbit-spin 8s linear infinite reverse;
  }

  @keyframes orbit-spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* 小彗星放在轨道边缘 */
  .orbit-ring .mini-comet {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%) rotate(0deg);
    display: flex;
    align-items: center;
  }

  /* 反转旋转让小彗星保持大致朝向 */
  .orbit-1 .mini-comet {
    animation: keep-upright 6s linear infinite;
  }
  .orbit-2 .mini-comet {
    animation: keep-upright 8s linear infinite reverse;
  }

  @keyframes keep-upright {
    0%   { transform: translateX(-50%) rotate(0deg); }
    100% { transform: translateX(-50%) rotate(-360deg); }
  }

  .mini-head {
    width: 5px;
    height: 5px;
    background: #fff;
    border-radius: 50%;
    box-shadow:
      0 0 3px #fff,
      0 0 8px #fff,
      0 0 16px #ffb8c6,
      0 0 24px #ff9ab5;
    flex-shrink: 0;
    animation: mini-twinkle 1.5s ease-in-out infinite;
  }

  @keyframes mini-twinkle {
    0%, 100% { opacity: 0.7; transform: scale(0.9); }
    50% { opacity: 1; transform: scale(1.25); }
  }

  .mini-tail {
    width: 70px;
    height: 1.5px;
    background: linear-gradient(to right,
      rgba(255,255,255,0.9) 0%,
      rgba(255,210,220,0.65) 15%,
      rgba(255,180,195,0.4) 35%,
      rgba(255,160,180,0.15) 60%,
      transparent 100%);
    border-radius: 1px;
    flex-shrink: 0;
  }

  /* 悬停时小彗星加速 */
  .comet-wrapper:hover .orbit-1 {
    animation-duration: 2.5s;
  }
  .comet-wrapper:hover .orbit-2 {
    animation-duration: 3.2s;
  }
  .comet-wrapper:hover .orbit-1 .mini-comet {
    animation-duration: 2.5s;
  }
  .comet-wrapper:hover .orbit-2 .mini-comet {
    animation-duration: 3.2s;
  }

  /* ====== 主彗星，自右上至左下倾斜 ====== */
  .tiamat-comet {
    position: relative;
    width: 300px;
    height: 120px;
    transform: rotate(145deg);
    transition: transform 0.3s ease;
  }

  .comet-wrapper:hover .tiamat-comet {
    transform: rotate(145deg) scale(1.06);
  }

  /* ====== 彗核 ====== */
  .nucleus {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    width: 60px;
    height: 60px;
    z-index: 5;
  }

  /* 核心白点 */
  .core-dot {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 8px; height: 8px;
    background: #fff;
    border-radius: 50%;
    box-shadow:
      0 0 3px #fff,
      0 0 8px #fff,
      0 0 18px #e0f0ff,
      0 0 30px #a0d4ff;
    z-index: 3;
    animation: core-twinkle 1.8s ease-in-out infinite;
  }

  @keyframes core-twinkle {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.35); }
  }

  /* 辉光环 */
  .glow-ring {
    position: absolute;
    inset: 0;
    margin: auto;
    border-radius: 50%;
    border: 1px solid rgba(180,220,255,0.5);
    animation: ring-breathe 2.5s ease-out infinite;
  }

  .ring-a {
    width: 20px; height: 20px;
    animation-delay: 0s;
    border-color: rgba(220,240,255,0.7);
  }

  .ring-b {
    width: 35px; height: 35px;
    animation-delay: 0.6s;
    border-color: rgba(170,210,255,0.45);
  }

  .ring-c {
    width: 52px; height: 52px;
    animation-delay: 1.2s;
    border-color: rgba(140,180,240,0.25);
  }

  @keyframes ring-breathe {
    0%   { opacity: 0.2; transform: scale(0.6); }
    40%  { opacity: 0.9; transform: scale(1); }
    100% { opacity: 0;   transform: scale(1.5); }
  }

  /* ====== 离子尾（蓝/青，细长明亮） ====== */
  .ion-tail {
    position: absolute;
    right: 45px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
  }

  .ion-tail-core {
    width: 200px;
    height: 2px;
    background: linear-gradient(to left,
      rgba(255,255,255,0.95) 0%,
      rgba(200,235,255,0.8) 10%,
      rgba(130,210,255,0.5) 35%,
      rgba(80,180,240,0.2) 65%,
      transparent 100%);
    border-radius: 1px;
    animation: ion-pulse 2s ease-in-out infinite;
  }

  .ion-tail-glow {
    position: absolute;
    top: -3px; left: 0;
    width: 200px;
    height: 8px;
    background: linear-gradient(to left,
      rgba(180,225,255,0.5) 0%,
      rgba(100,195,240,0.25) 30%,
      transparent 100%);
    border-radius: 4px;
    filter: blur(3px);
    animation: ion-pulse 2s ease-in-out 0.3s infinite;
  }

  @keyframes ion-pulse {
    0%, 100% { opacity: 0.75; }
    50% { opacity: 1; }
  }

  /* ====== 尘埃尾（浅天蓝，宽而弥散） ====== */
  .dust-tail {
    position: absolute;
    right: 40px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
  }

  .dust-tail-core {
    width: 240px;
    height: 3px;
    background: linear-gradient(to left,
      rgba(200,235,255,0.8) 0%,
      rgba(150,215,245,0.5) 15%,
      rgba(100,195,235,0.3) 40%,
      rgba(60,170,220,0.1) 70%,
      transparent 100%);
    border-radius: 1.5px;
    animation: dust-shift 2.4s ease-in-out infinite;
  }

  .dust-tail-glow {
    position: absolute;
    top: -8px; left: 0;
    width: 240px;
    height: 22px;
    background: linear-gradient(to left,
      rgba(180,225,250,0.35) 0%,
      rgba(130,210,240,0.18) 25%,
      rgba(80,190,230,0.06) 60%,
      transparent 100%);
    border-radius: 11px;
    filter: blur(6px);
    animation: dust-shift 2.4s ease-in-out 0.5s infinite;
  }

  @keyframes dust-shift {
    0%, 100% { opacity: 0.6; transform: translateY(0); }
    50% { opacity: 0.9; transform: translateY(-2px); }
  }

  /* ====== 碎片粒子 ====== */
  .fragments {
    position: absolute;
    inset: 0;
    z-index: 4;
  }

  .frag {
    position: absolute;
    border-radius: 50%;
    background: #fff;
    animation: frag-drift 2.8s ease-out infinite;
  }

  .f1 { width: 3px; height: 3px; top: 52%; left: 20%;
        box-shadow: 0 0 6px #7dd3fc; animation-delay: 0s; }
  .f2 { width: 2px; height: 2px; top: 38%; left: 35%;
        box-shadow: 0 0 4px #a5e0ff; animation-delay: 0.4s; }
  .f3 { width: 2.5px; height: 2.5px; top: 58%; left: 28%;
        box-shadow: 0 0 5px #87ceeb; animation-delay: 0.7s; }
  .f4 { width: 1.5px; height: 1.5px; top: 44%; left: 50%;
        box-shadow: 0 0 3px #b0e0ff; animation-delay: 1.0s; }
  .f5 { width: 2px; height: 2px; top: 55%; left: 42%;
        box-shadow: 0 0 4px #9ad5f0; animation-delay: 1.3s; }
  .f6 { width: 1.8px; height: 1.8px; top: 60%; left: 55%;
        box-shadow: 0 0 3px #c0e8ff; animation-delay: 1.6s; }
  .f7 { width: 2.2px; height: 2.2px; top: 40%; left: 48%;
        box-shadow: 0 0 5px #7ec8e3; animation-delay: 1.9s; }
  .f8 { width: 1.5px; height: 1.5px; top: 48%; left: 62%;
        box-shadow: 0 0 3px #a0d8f0; animation-delay: 2.2s; }

  @keyframes frag-drift {
    0%   { opacity: 0; transform: translate(0, 0) scale(0.3); }
    15%  { opacity: 1; transform: translate(-4px, -2px) scale(1); }
    40%  { opacity: 0.7; transform: translate(-10px, 3px) scale(0.8); }
    100% { opacity: 0; transform: translate(-20px, -4px) scale(0.1); }
  }

  /* ====== 悬停增强 ====== */
  .comet-wrapper:hover .core-dot {
    animation-duration: 0.7s;
    box-shadow:
      0 0 5px #fff,
      0 0 12px #fff,
      0 0 26px #87ceeb,
      0 0 42px #5bbce4;
  }

  .comet-wrapper:hover .ring-a,
  .comet-wrapper:hover .ring-b,
  .comet-wrapper:hover .ring-c {
    animation-duration: 1.2s;
  }

  /* ====== 响应式 ====== */
  @media (max-width: 480px) {
    .orbit-1 {
      width: 180px; height: 180px;
      margin: -90px 0 0 -90px;
    }
    .orbit-2 {
      width: 240px; height: 240px;
      margin: -120px 0 0 -120px;
    }

    .mini-tail {
      width: 45px;
    }

    .tiamat-comet {
      width: 210px;
      height: 85px;
      transform: rotate(145deg);
    }

    .comet-wrapper:hover .tiamat-comet {
      transform: rotate(145deg) scale(1.06);
    }

    .nucleus {
      right: 10px;
      width: 42px; height: 42px;
    }

    .core-dot {
      width: 6px; height: 6px;
    }

    .ion-tail-core {
      width: 140px;
    }
    .ion-tail-glow {
      width: 140px;
    }

    .dust-tail-core {
      width: 170px;
    }
    .dust-tail-glow {
      width: 170px;
    }
  }
</style>
