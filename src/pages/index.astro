---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="欢迎" showNavbar={false} showFooter={false} showMusic={false}>
  <div class="splash" id="splash">
    <!-- 阶段1：首页动画（手动播放） -->
    <video
      id="video-shouye"
      class="splash-video active"
      src="/video/shouye.mp4"
      muted
      playsinline
      preload="auto"
    ></video>

    <!-- 阶段2：转场动画（自动播放，初始隐藏） -->
    <video
      id="video-zhuanchang"
      class="splash-video"
      src="/video/zhuanchang.mp4"
      muted
      playsinline
      preload="auto"
    ></video>

    <!-- 中心闪光点 -->
    <div class="glow-dot-wrapper" id="glow-dot">
      <div class="glow-dot">
        <div class="glow-ring ring-1"></div>
        <div class="glow-ring ring-2"></div>
        <div class="glow-ring ring-3"></div>
        <div class="glow-core"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const shouye = document.getElementById('video-shouye');
  const zhuanchang = document.getElementById('video-zhuanchang');
  const glowDot = document.getElementById('glow-dot');

  const startFlow = () => {
    glowDot.classList.add('hidden');
    shouye.playbackRate = 1.25;
    shouye.play().catch(() => {
      // 播放失败，直接跳转阶段2
      shouye.classList.remove('active');
      zhuanchang.classList.add('active');
      zhuanchang.play().catch(() => {
        document.querySelector('.splash').style.opacity = '0';
        setTimeout(() => window.location.href = '/diary', 400);
      });
    });
  };

  // 点击闪光点开始
  glowDot.addEventListener('click', startFlow);

  // 阶段1 → 阶段2
  shouye.addEventListener('ended', () => {
    shouye.classList.remove('active');
    zhuanchang.classList.add('active');
    zhuanchang.play().catch(() => {});
  });

  // 阶段2 → 跳转
  zhuanchang.addEventListener('ended', () => {
    document.querySelector('.splash').style.opacity = '0';
    setTimeout(() => window.location.href = '/diary', 400);
  });

  zhuanchang.addEventListener('error', () => {
    window.location.href = '/diary';
  });
</script>

<style>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    overflow: hidden;
    transition: opacity 0.5s ease;
  }

  .splash-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .splash-video.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ===== 中心闪光点 ===== */
  .glow-dot-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    cursor: pointer;
    transition: opacity 0.5s ease;
  }

  .glow-dot-wrapper.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .glow-dot {
    position: relative;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 核心亮点 */
  .glow-core {
    width: 12px;
    height: 12px;
    background: #fff;
    border-radius: 50%;
    z-index: 3;
    box-shadow:
      0 0 10px #fff,
      0 0 30px rgba(255,255,255,0.9),
      0 0 60px rgba(240,132,108,0.7),
      0 0 100px rgba(240,132,108,0.4);
    animation: pulse-core 1.8s ease-in-out infinite;
  }

  @keyframes pulse-core {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.6); opacity: 0.6; }
  }

  /* 扩散光环 */
  .glow-ring {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.5);
    animation: ring-expand 2.4s ease-out infinite;
  }

  .ring-1 { animation-delay: 0s; }
  .ring-2 { animation-delay: 0.8s; }
  .ring-3 { animation-delay: 1.6s; }

  @keyframes ring-expand {
    0% {
      width: 12px;
      height: 12px;
      opacity: 0.9;
    }
    100% {
      width: 90px;
      height: 90px;
      opacity: 0;
    }
  }

  /* 悬停增强 */
  .glow-dot-wrapper:hover .glow-core {
    box-shadow:
      0 0 14px #fff,
      0 0 40px rgba(255,255,255,1),
      0 0 80px rgba(240,132,108,0.9),
      0 0 130px rgba(240,132,108,0.6);
  }

  .glow-dot-wrapper:hover .glow-ring {
    border-color: rgba(255,255,255,0.8);
  }

  @media (max-width: 480px) {
    .glow-dot {
      width: 60px;
      height: 60px;
    }
    .glow-core {
      width: 10px;
      height: 10px;
    }
    @keyframes ring-expand {
      0% { width: 10px; height: 10px; opacity: 0.9; }
      100% { width: 70px; height: 70px; opacity: 0; }
    }
  }
</style>
