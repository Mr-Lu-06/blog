---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="欢迎" showNavbar={false} showFooter={false} showMusic={false}>
  <div class="splash" id="splash">
    <!-- 阶段1：首页动画（手动播放） -->
    <video
      id="video-shouye"
      class="splash-video active"
      src="/video/shouye.mp4"
      muted
      playsinline
      preload="auto"
    ></video>

    <!-- 阶段2：转场动画（自动播放，初始隐藏） -->
    <video
      id="video-zhuanchang"
      class="splash-video"
      src="/video/zhuanchang.mp4"
      muted
      playsinline
      preload="auto"
    ></video>

    <!-- 彗星播放按钮 -->
    <div class="comet-wrapper" id="glow-dot">
      <div class="comet-orbit">
        <div class="comet">
          <div class="comet-head"></div>
          <div class="comet-tail"></div>
          <!-- 尾迹粒子 -->
          <div class="comet-particle p1"></div>
          <div class="comet-particle p2"></div>
          <div class="comet-particle p3"></div>
          <div class="comet-particle p4"></div>
          <div class="comet-particle p5"></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const shouye = document.getElementById('video-shouye');
  const zhuanchang = document.getElementById('video-zhuanchang');
  const glowDot = document.getElementById('glow-dot');

  const startFlow = () => {
    glowDot.classList.add('hidden');
    shouye.playbackRate = 1.5;
    shouye.play().catch(() => {
      // 播放失败，直接跳转阶段2
      shouye.classList.remove('active');
      zhuanchang.classList.add('active');
      zhuanchang.play().catch(() => {
        document.querySelector('.splash').style.opacity = '0';
        setTimeout(() => window.location.href = '/diary', 400);
      });
    });
  };

  // 点击闪光点开始
  glowDot.addEventListener('click', startFlow);

  // 阶段1 → 阶段2
  shouye.addEventListener('ended', () => {
    shouye.classList.remove('active');
    zhuanchang.classList.add('active');
    zhuanchang.play().catch(() => {});
  });

  // 阶段2 → 跳转
  zhuanchang.addEventListener('ended', () => {
    document.querySelector('.splash').style.opacity = '0';
    setTimeout(() => window.location.href = '/diary', 400);
  });

  zhuanchang.addEventListener('error', () => {
    window.location.href = '/diary';
  });
</script>

<style>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    overflow: hidden;
    transition: opacity 0.5s ease;
  }

  .splash-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .splash-video.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ===== 七彩彗星播放按钮 ===== */
  .comet-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    cursor: pointer;
    transition: opacity 0.5s ease;
  }

  .comet-wrapper.hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* 容器（无旋转） */
  .comet-orbit {
    width: 200px;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  /* 彗星本体 */
  .comet {
    position: relative;
    width: 0;
    height: 0;
  }

  /* 彗核：白色核心 + 七彩辉光 */
  .comet-head {
    position: absolute;
    width: 10px;
    height: 10px;
    background: #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow:
      0 0 4px #fff,
      0 0 10px #fff,
      0 0 20px #ff0000,
      0 0 30px #ff7f00,
      0 0 40px #ffff00,
      0 0 50px #00ff00,
      0 0 60px #0000ff,
      0 0 70px #4b0082,
      0 0 80px #9400d3;
    animation: comet-glow 2s ease-in-out infinite;
  }

  /* 彗核七彩呼吸 */
  @keyframes comet-glow {
    0%, 100% {
      box-shadow:
        0 0 4px #fff,
        0 0 10px #fff,
        0 0 20px #ff0000,
        0 0 30px #ff7f00,
        0 0 40px #ffff00,
        0 0 50px #00ff00,
        0 0 60px #0000ff,
        0 0 70px #4b0082,
        0 0 80px #9400d3;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      box-shadow:
        0 0 6px #fff,
        0 0 14px #fff,
        0 0 28px #ff0000,
        0 0 40px #ff7f00,
        0 0 52px #ffff00,
        0 0 64px #00ff00,
        0 0 76px #0000ff,
        0 0 88px #4b0082,
        0 0 100px #9400d3;
      transform: translate(-50%, -50%) scale(1.3);
    }
  }

  /* 彗尾：七彩渐变拖尾 */
  .comet-tail {
    position: absolute;
    top: 0;
    left: -120px;
    width: 110px;
    height: 3px;
    background: linear-gradient(to left,
      rgba(255,255,255,0.95) 0%,
      #ff0000 8%,
      #ff7f00 20%,
      #ffff00 33%,
      #00ff00 46%,
      #0000ff 60%,
      #4b0082 74%,
      #9400d3 87%,
      transparent 100%);
    border-radius: 2px;
    transform: translateY(-50%);
    filter: blur(0.5px);
    animation: tail-shimmer 2s ease-in-out infinite;
  }

  @keyframes tail-shimmer {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 1; }
  }

  /* 尾迹粒子 — 七色分配 */
  .comet-particle {
    position: absolute;
    border-radius: 50%;
    animation: particle-fade 2.2s ease-out infinite;
  }

  .comet-particle.p1 {
    width: 4px; height: 4px;
    left: -25px; top: -5px;
    animation-delay: 0s;
    background: #ff0000;
    box-shadow: 0 0 8px #ff0000;
  }

  .comet-particle.p2 {
    width: 3.5px; height: 3.5px;
    left: -45px; top: 6px;
    animation-delay: 0.4s;
    background: #ffaa00;
    box-shadow: 0 0 7px #ffaa00;
  }

  .comet-particle.p3 {
    width: 3px; height: 3px;
    left: -60px; top: -3px;
    animation-delay: 0.8s;
    background: #33cc33;
    box-shadow: 0 0 6px #33cc33;
  }

  .comet-particle.p4 {
    width: 2.5px; height: 2.5px;
    left: -75px; top: 2px;
    animation-delay: 1.2s;
    background: #6666ff;
    box-shadow: 0 0 5px #6666ff;
  }

  .comet-particle.p5 {
    width: 2px; height: 2px;
    left: -90px; top: -1px;
    animation-delay: 1.6s;
    background: #cc33ff;
    box-shadow: 0 0 4px #cc33ff;
  }

  /* 粒子闪烁消散 */
  @keyframes particle-fade {
    0%   { opacity: 0;   transform: scale(0.2); }
    15%  { opacity: 1;   transform: scale(1.2); }
    100% { opacity: 0;   transform: scale(0); }
  }

  /* 悬停增强 */
  .comet-wrapper:hover .comet-head {
    animation-duration: 0.8s;
  }

  .comet-wrapper:hover .comet-tail {
    filter: blur(0px);
    opacity: 1;
  }

  @media (max-width: 480px) {
    .comet-orbit {
      width: 140px;
      height: 70px;
    }

    .comet-head {
      width: 8px; height: 8px;
    }

    .comet-tail {
      width: 75px;
      left: -82px;
      height: 2px;
    }

    .comet-particle.p1 { left: -20px; }
    .comet-particle.p2 { left: -32px; }
    .comet-particle.p3 { left: -44px; }
    .comet-particle.p4 { left: -55px; }
    .comet-particle.p5 { left: -65px; }
  }
</style>
