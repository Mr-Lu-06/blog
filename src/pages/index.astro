---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="欢迎" showNavbar={false} showFooter={false} showMusic={false}>
  <div class="splash" id="splash">
    <!-- 阶段1：首页动画（手动播放） -->
    <video
      id="video-shouye"
      class="splash-video active"
      src="/video/shouye.mp4"
      muted
      playsinline
      preload="auto"
    ></video>

    <!-- 阶段2：转场动画（自动播放，初始隐藏） -->
    <video
      id="video-zhuanchang"
      class="splash-video"
      src="/video/zhuanchang.mp4"
      muted
      playsinline
      preload="auto"
    ></video>

    <!-- 彗星播放按钮 -->
    <div class="comet-wrapper" id="glow-dot">
      <div class="comet-orbit">
        <div class="comet">
          <div class="comet-head"></div>
          <div class="comet-tail"></div>
          <!-- 尾迹粒子 -->
          <div class="comet-particle p1"></div>
          <div class="comet-particle p2"></div>
          <div class="comet-particle p3"></div>
          <div class="comet-particle p4"></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const shouye = document.getElementById('video-shouye');
  const zhuanchang = document.getElementById('video-zhuanchang');
  const glowDot = document.getElementById('glow-dot');

  const startFlow = () => {
    glowDot.classList.add('hidden');
    shouye.playbackRate = 1.5;
    shouye.play().catch(() => {
      // 播放失败，直接跳转阶段2
      shouye.classList.remove('active');
      zhuanchang.classList.add('active');
      zhuanchang.play().catch(() => {
        document.querySelector('.splash').style.opacity = '0';
        setTimeout(() => window.location.href = '/diary', 400);
      });
    });
  };

  // 点击闪光点开始
  glowDot.addEventListener('click', startFlow);

  // 阶段1 → 阶段2
  shouye.addEventListener('ended', () => {
    shouye.classList.remove('active');
    zhuanchang.classList.add('active');
    zhuanchang.play().catch(() => {});
  });

  // 阶段2 → 跳转
  zhuanchang.addEventListener('ended', () => {
    document.querySelector('.splash').style.opacity = '0';
    setTimeout(() => window.location.href = '/diary', 400);
  });

  zhuanchang.addEventListener('error', () => {
    window.location.href = '/diary';
  });
</script>

<style>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    overflow: hidden;
    transition: opacity 0.5s ease;
  }

  .splash-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .splash-video.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ===== 彗星播放按钮 ===== */
  .comet-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    cursor: pointer;
    transition: opacity 0.5s ease;
  }

  .comet-wrapper.hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* 椭圆轨道容器 */
  .comet-orbit {
    width: 180px;
    height: 180px;
    animation: orbit-spin 3s linear infinite;
  }

  /* 彗星本体（挂在旋转容器内） */
  .comet {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
  }

  /* 彗核：明亮的光点 */
  .comet-head {
    position: absolute;
    width: 9px;
    height: 9px;
    background: #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow:
      0 0 6px #fff,
      0 0 16px rgba(255,255,255,0.95),
      0 0 35px rgba(255,200,150,0.8),
      0 0 60px rgba(240,132,108,0.5);
  }

  /* 彗尾：渐变拖尾 */
  .comet-tail {
    position: absolute;
    top: 0;
    left: -90px;
    width: 80px;
    height: 2px;
    background: linear-gradient(to left,
      rgba(255,255,255,0.9) 0%,
      rgba(255,220,180,0.6) 25%,
      rgba(240,132,108,0.25) 60%,
      transparent 100%);
    border-radius: 1px;
    transform: translateY(-50%);
  }

  /* 尾迹粒子 */
  .comet-particle {
    position: absolute;
    border-radius: 50%;
    background: #fff;
    animation: particle-fade 2.2s ease-out infinite;
  }

  .comet-particle.p1 {
    width: 4px;
    height: 4px;
    left: -30px;
    top: -3px;
    animation-delay: 0s;
    box-shadow: 0 0 6px rgba(255,200,150,0.7);
  }

  .comet-particle.p2 {
    width: 3px;
    height: 3px;
    left: -50px;
    top: 4px;
    animation-delay: 0.5s;
    box-shadow: 0 0 4px rgba(255,180,130,0.6);
  }

  .comet-particle.p3 {
    width: 2.5px;
    height: 2.5px;
    left: -65px;
    top: -2px;
    animation-delay: 1.0s;
    box-shadow: 0 0 3px rgba(240,132,108,0.5);
  }

  .comet-particle.p4 {
    width: 2px;
    height: 2px;
    left: -78px;
    top: 1px;
    animation-delay: 1.6s;
    box-shadow: 0 0 2px rgba(240,132,108,0.35);
  }

  /* 粒子闪烁消散 */
  @keyframes particle-fade {
    0% {
      opacity: 0;
      transform: scale(0.3);
    }
    20% {
      opacity: 1;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(0.1);
    }
  }

  /* 椭圆轨道旋转 */
  @keyframes orbit-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* 悬停加速 */
  .comet-wrapper:hover .comet-orbit {
    animation-duration: 1.2s;
  }

  .comet-wrapper:hover .comet-head {
    box-shadow:
      0 0 10px #fff,
      0 0 24px rgba(255,255,255,1),
      0 0 50px rgba(255,200,150,0.95),
      0 0 80px rgba(240,132,108,0.7);
  }

  .comet-wrapper:hover .comet-tail {
    background: linear-gradient(to left,
      rgba(255,255,255,1) 0%,
      rgba(255,220,180,0.8) 30%,
      rgba(240,132,108,0.4) 65%,
      transparent 100%);
  }

  @media (max-width: 480px) {
    .comet-orbit {
      width: 130px;
      height: 130px;
    }

    .comet-head {
      width: 7px;
      height: 7px;
    }

    .comet-tail {
      width: 55px;
      left: -60px;
    }

    .comet-particle.p1 { left: -22px; }
    .comet-particle.p2 { left: -35px; }
    .comet-particle.p3 { left: -45px; }
    .comet-particle.p4 { left: -52px; }
  }
</style>
