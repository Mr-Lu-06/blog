---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import Lightbox from '../components/Lightbox.jsx';
import { sortByDate, formatDate } from '../utils/date';

const galleries = await getCollection('gallery');
const sorted = sortByDate(galleries);
---

<BaseLayout title="相册" description="记录生活中的美好瞬间">
  <div class="container gallery-page">
    <h1 style="font-size:1.6rem;font-weight:900;margin-bottom:20px;">相册</h1>

    <!-- Token 设置（与写日记页相同） -->
    <div class="token-bar" id="token-bar">
      <input type="password" id="token-input" placeholder="GitHub Token（首次使用需填写）" />
      <button class="t-btn small" id="btn-save-token">保存</button>
      <a href="https://github.com/settings/tokens/new?scopes=repo&description=blog-write" target="_blank" class="token-help">创建 Token →</a>
    </div>

    <!-- 新建相册表单 -->
    <div class="form-card glass" id="form-card" style="display:none;">
      <h2>新建相册</h2>
      <input type="text" id="field-title" class="field" placeholder="相册名称" />
      <div class="row">
        <input type="date" id="field-date" class="field" />
        <input type="text" id="field-cover" class="field" placeholder="封面图片 URL（可选）" />
      </div>
      <textarea id="field-photos" class="field field-area" placeholder="照片列表，每行一张图片 URL，描述用 | 分隔&#10;例如：&#10;https://xxx.jpg | 湖边的风景&#10;https://yyy.jpg | 阳光穿过树叶" rows="6"></textarea>
      <div class="form-actions">
        <button class="t-btn primary" id="btn-publish">保存</button>
        <button class="t-btn" id="btn-cancel-form">取消</button>
      </div>
    </div>

    <!-- 操作栏 -->
    <div class="bar">
      <button class="t-btn primary" id="btn-new">+ 新建相册</button>
      <span class="bar-hint">已有 {sorted.length} 个相册</span>
    </div>

    <!-- 相册列表 -->
    {sorted.length > 0 ? (
      <div class="gallery-list" id="gallery-list">
        {sorted.map((entry) => (
          <div class="gallery-section glass" data-slug={entry.id}>
            <div class="gallery-section-header">
              <div>
                <h2>{entry.data.title}</h2>
                <time>{formatDate(entry.data.date.toISOString())}</time>
              </div>
              <button class="t-btn small btn-del" data-slug={entry.id}>删除</button>
            </div>
            <PhotoGrid photos={entry.data.photos || []} />
          </div>
        ))}
      </div>
    ) : (
      <p class="empty">还没有相册，点击上方按钮创建！</p>
    )}
  </div>
</BaseLayout>

<Lightbox client:load />
<div id="toast"></div>

<style>
  .gallery-page { padding-top: 20px; padding-bottom: 60px; max-width: 900px; }
  .gallery-list { display: flex; flex-direction: column; gap: 28px; }
  .gallery-section { border-radius: var(--radius-lg); padding: 20px; }
  .gallery-section-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 10px; margin-bottom: 12px;
  }
  .gallery-section-header h2 { font-size: 1.1rem; font-weight: 800; margin: 0 0 3px; }
  .gallery-section-header time { color: var(--text-muted); font-size: 0.82rem; }

  /* Token */
  .token-bar {
    display: flex; gap: 8px; align-items: center; padding: 10px 14px;
    background: var(--bg-card); border: 1px solid var(--border-color);
    border-radius: 10px; margin-bottom: 16px; flex-wrap: wrap;
  }
  .token-bar input {
    flex: 1; min-width: 150px; padding: 7px 10px;
    border: 1px solid var(--border-color); border-radius: 6px;
    font-size: 0.85rem; font-family: inherit; background: var(--bg-secondary);
    color: var(--text-primary); outline: none;
  }
  .token-bar input:focus { border-color: var(--accent); }
  .token-help { font-size: 0.82rem; color: var(--accent); white-space: nowrap; }

  /* Buttons */
  .t-btn {
    padding: 8px 18px; border: 1px solid var(--border-color); border-radius: 8px;
    background: var(--bg-card); color: var(--text-primary);
    font-size: 0.88rem; cursor: pointer; font-family: inherit; transition: all 0.2s;
  }
  .t-btn:hover { border-color: var(--accent); color: var(--accent); }
  .t-btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .t-btn.primary:hover { background: var(--accent-hover); color: #fff; }
  .t-btn.small { padding: 5px 12px; font-size: 0.8rem; }
  .btn-del:hover { color: #d32f2f !important; border-color: #d32f2f !important; }

  /* Form */
  .form-card {
    border-radius: var(--radius-lg); padding: 24px; margin-bottom: 20px;
  }
  .form-card h2 { font-size: 1.1rem; margin: 0 0 14px; }
  .field {
    width: 100%; padding: 9px 12px; border: 1px solid var(--border-color);
    border-radius: 8px; background: var(--bg-card); color: var(--text-primary);
    font-size: 0.9rem; font-family: inherit; outline: none; margin-bottom: 10px;
    box-sizing: border-box;
  }
  .field:focus { border-color: var(--accent); }
  .field-area { resize: vertical; min-height: 120px; }
  .row { display: flex; gap: 10px; }
  .row .field { flex: 1; }
  .form-actions { display: flex; gap: 10px; margin-top: 4px; }

  .bar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px; flex-wrap: wrap; gap: 10px;
  }
  .bar-hint { color: var(--text-muted); font-size: 0.85rem; }
  .empty { text-align: center; padding: 50px 20px; color: var(--text-secondary); }

  /* Toast */
  #toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
    padding: 10px 24px; border-radius: 8px; font-size: 0.85rem;
    z-index: 999; display: none; box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  }
  #toast.show { display: block; }
  #toast.success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
  #toast.error { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
  #toast.loading { background: #cce5ff; color: #004085; border: 1px solid #b8daff; }

  @media (max-width: 480px) {
    .row { flex-direction: column; }
  }
</style>

<script>
  // ===== 与写日记页完全一致的 GitHub API 模式 =====
  const REPO = 'Mr-Lu-06/blog';
  const BRANCH = 'main';
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('field-date').value = today;

  // Toast
  const toastEl = document.getElementById('toast');
  function toast(msg, type) {
    toastEl.textContent = msg; toastEl.className = type + ' show';
    clearTimeout(toastEl._t);
    toastEl._t = setTimeout(function() { toastEl.classList.remove('show'); }, 3000);
  }

  // Token
  var savedToken = localStorage.getItem('write_token');
  if (savedToken) document.getElementById('token-input').value = savedToken;
  document.getElementById('btn-save-token').addEventListener('click', function() {
    var v = document.getElementById('token-input').value.trim();
    if (!v) return toast('请输入 Token', 'error');
    localStorage.setItem('write_token', v);
    toast('Token 已保存', 'success');
  });
  function getToken() {
    var t = document.getElementById('token-input').value.trim();
    if (!t) t = localStorage.getItem('write_token');
    return t;
  }

  // 新建按钮
  document.getElementById('btn-new').addEventListener('click', function() {
    document.getElementById('form-card').style.display = 'block';
    document.getElementById('field-title').value = '';
    document.getElementById('field-date').value = today;
    document.getElementById('field-cover').value = '';
    document.getElementById('field-photos').value = '';
    document.getElementById('field-title').focus();
  });

  // 取消按钮
  document.getElementById('btn-cancel-form').addEventListener('click', function() {
    document.getElementById('form-card').style.display = 'none';
  });

  // 保存（完全复制写日记页的 publish 逻辑）
  document.getElementById('btn-publish').addEventListener('click', async function() {
    var token = getToken();
    if (!token) return toast('请先填写 GitHub Token', 'error');

    var title = document.getElementById('field-title').value.trim() || '未命名相册';
    var date = document.getElementById('field-date').value || today;
    var cover = document.getElementById('field-cover').value.trim();
    var photosText = document.getElementById('field-photos').value.trim();

    if (!photosText) return toast('请填写照片 URL', 'error');

    // 解析照片：每行 "url | caption" 或 "url"
    var photos = photosText.split('\n').map(function(line) {
      var parts = line.split('|');
      var photo = { url: (parts[0] || '').trim() };
      if (parts[1] && parts[1].trim()) photo.caption = parts[1].trim();
      return photo;
    }).filter(function(p) { return p.url; });

    if (photos.length === 0) return toast('请填写至少一张照片 URL', 'error');

    // 构建 YAML
    var yaml = '---\ntitle: "' + title.replace(/"/g, '\\"') + '"\ndate: ' + date + '\nphotos:\n';
    photos.forEach(function(p) {
      yaml += '  - url: "' + p.url.replace(/"/g, '\\"') + '"\n';
      if (p.caption) yaml += '    caption: "' + p.caption.replace(/"/g, '\\"') + '"\n';
    });
    if (cover) yaml += 'cover: "' + cover.replace(/"/g, '\\"') + '"\n';
    yaml += '---\n';

    var slug = date + '-' + title.replace(/[^一-龥a-zA-Z0-9]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').substring(0, 40);
    var filepath = 'src/content/gallery/' + slug + '.md';
    var fullContent = yaml;

    toast('正在保存...', 'loading');

    try {
      var sha = null;
      try {
        var checkRes = await fetch('https://api.github.com/repos/' + REPO + '/contents/' + filepath, {
          headers: { Authorization: 'Bearer ' + token, Accept: 'application/vnd.github.v3+json' }
        });
        if (checkRes.ok) { var info = await checkRes.json(); sha = info.sha; }
      } catch(e) {}

      var payload = {
        message: '相册: ' + title,
        content: btoa(unescape(encodeURIComponent(fullContent))),
        branch: BRANCH,
      };
      if (sha) payload.sha = sha;

      var res = await fetch('https://api.github.com/repos/' + REPO + '/contents/' + filepath, {
        method: 'PUT',
        headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json', Accept: 'application/vnd.github.v3+json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        var errText = await res.text();
        throw new Error(res.status + ': ' + errText.substring(0, 150));
      }

      toast('已保存！部署中，稍后刷新查看...', 'success');
      document.getElementById('form-card').style.display = 'none';
      setTimeout(function() { location.reload(); }, 2500);
    } catch(e) {
      toast('保存失败: ' + e.message, 'error');
    }
  });

  // 删除（完全复制写日记页的 deleteDiary 逻辑）
  document.getElementById('gallery-list').addEventListener('click', async function(e) {
    var btn = e.target.closest('.btn-del');
    if (!btn) return;
    var slug = btn.dataset.slug;
    if (!confirm('确定要删除这个相册吗？')) return;

    var token = getToken();
    if (!token) return toast('请先填写 GitHub Token', 'error');

    var filepath = 'src/content/gallery/' + slug + '.md';
    toast('正在删除...', 'loading');

    try {
      var infoRes = await fetch('https://api.github.com/repos/' + REPO + '/contents/' + filepath, {
        headers: { Authorization: 'Bearer ' + token, Accept: 'application/vnd.github.v3+json' }
      });
      if (infoRes.status === 404) return toast('文件不存在', 'error');
      if (!infoRes.ok) throw new Error(infoRes.status);
      var info = await infoRes.json();

      var delRes = await fetch('https://api.github.com/repos/' + REPO + '/contents/' + filepath, {
        method: 'DELETE',
        headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json', Accept: 'application/vnd.github.v3+json' },
        body: JSON.stringify({ message: '删除相册: ' + slug, sha: info.sha, branch: BRANCH }),
      });
      if (!delRes.ok) {
        var eText = await delRes.text();
        throw new Error(delRes.status + ': ' + eText.substring(0, 100));
      }

      toast('已删除！部署中...', 'success');
      setTimeout(function() { location.reload(); }, 2000);
    } catch(e) {
      toast('删除失败: ' + e.message, 'error');
    }
  });
</script>
