---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const diaries = await getCollection('diary');
  return diaries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, date, tags, mood, weather, featured_image } = entry.data;
const html = entry.rendered?.html;
---

<BaseLayout title={title} description={entry.rendered?.html?.replace(/<[^>]*>/g, '').substring(0, 160)}>
  <div class="container-narrow diary-page">
    <a href="/" class="back-link">
      <span class="back-arrow">←</span> 返回首页
    </a>

    <article class="diary-detail glass">
      <header class="diary-header">
        <div class="diary-header-meta">
          <time datetime={date.toISOString()}>{formatDate(date.toISOString())}</time>
          <div class="diary-header-badges">
            {mood && <span class="diary-badge mood">{mood}</span>}
            {weather && <span class="diary-badge weather">{weather}</span>}
          </div>
        </div>
        <h1 class="diary-title">{title}</h1>
        {
          tags.length > 0 && (
            <div class="diary-header-tags">
              {tags.map(tag => <span class="diary-header-tag">#{tag}</span>)}
            </div>
          )
        }
      </header>

      {
        featured_image && (
          <div class="diary-featured-image">
            <img src={featured_image} alt={title} />
          </div>
        )
      }

      <div class="markdown-body diary-content" set:html={html}>
      </div>

      <footer class="diary-footer">
        <div class="diary-footer-divider"></div>
        <a href="/" class="back-link">
          <span class="back-arrow">←</span> 返回首页看更多
        </a>
      </footer>
    </article>
  </div>
</BaseLayout>

<style>
  .diary-page {
    padding-top: 32px;
    padding-bottom: 60px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 20px;
    transition: all 0.25s ease;
    font-weight: 500;
  }
  .back-link:hover {
    color: var(--accent);
    transform: translateX(-4px);
  }
  .back-arrow {
    transition: transform 0.25s ease;
  }
  .back-link:hover .back-arrow {
    transform: translateX(-3px);
  }

  .diary-detail {
    border-radius: var(--radius-xl);
    padding: 44px 48px;
    transition: all 0.4s ease;
  }

  .diary-detail:hover {
    box-shadow: var(--shadow-md);
  }

  .diary-header {
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 2px solid var(--accent-soft);
  }

  .diary-header-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .diary-header-badges {
    display: flex;
    gap: 8px;
  }

  .diary-badge {
    padding: 4px 14px;
    border-radius: 16px;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .diary-badge.mood {
    background: var(--accent-light);
    color: var(--tag-text);
  }

  .diary-badge.weather {
    background: var(--accent2-light);
    color: var(--tag-text2);
  }

  .diary-title {
    font-size: 2rem;
    font-weight: 900;
    margin: 0 0 14px;
    line-height: 1.3;
  }

  .diary-header-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .diary-header-tag {
    padding: 3px 12px;
    border-radius: 8px;
    background: var(--tag-bg);
    color: var(--tag-text);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .diary-featured-image {
    margin-bottom: 28px;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .diary-featured-image img {
    width: 100%;
    border-radius: var(--radius);
    transition: transform 0.4s ease;
  }

  .diary-featured-image img:hover {
    transform: scale(1.01);
  }

  .diary-content {
    min-height: 200px;
  }

  .diary-footer {
    margin-top: 48px;
    padding-top: 24px;
  }

  .diary-footer-divider {
    height: 2px;
    background: var(--gradient-warm);
    border-radius: 1px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  @media (max-width: 768px) {
    .diary-detail {
      padding: 28px 24px;
      border-radius: var(--radius-lg);
    }
    .diary-title {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .diary-detail {
      padding: 24px 18px;
      border-radius: var(--radius);
    }
    .diary-title {
      font-size: 1.3rem;
    }
  }
</style>
