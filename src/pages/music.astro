<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>音乐</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: system-ui, 'PingFang SC', -apple-system, sans-serif;
      min-height: 100vh;
      background: #0a0a0a;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      cursor: grab;
      user-select: none;
      -webkit-user-select: none;
    }
    body:active { cursor: grabbing; }

    /* ===== 视频背景 ===== */
    .bg-video {
      position: fixed; inset: 0; z-index: -1;
    }
    .bg-video video {
      width: 100%; height: 100%; object-fit: cover;
    }
    .bg-overlay {
      position: fixed; inset: 0; z-index: 0;
      background: linear-gradient(to bottom,
        rgba(0,0,0,0.10) 0%,
        rgba(0,0,0,0.50) 100%
      );
    }

    /* ===== 返回按钮 ===== */
    .close-btn {
      position: fixed; top: 12px; right: 14px; z-index: 100;
      width: 28px; height: 28px; border-radius: 50%;
      background: rgba(0,0,0,0.35); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.1);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.95rem; color: rgba(255,255,255,0.7);
      transition: all 0.2s;
      text-decoration: none;
    }
    .close-btn:hover { background: rgba(0,0,0,0.5); color: #fff; }

    /* ===== 卡片包裹容器（整体拖拽目标） ===== */
    .cards-wrapper {
      display: flex;
      gap: 100px;
      align-items: center;
      justify-content: center;
      z-index: 1;
    }

    /* ===== 播放器卡片 ===== */
    .player-card {
      position: relative;
      width: 220px;
      border-radius: 14px;
      background: rgba(20,20,25,0.35);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 24px 80px rgba(0,0,0,0.6);
      overflow: hidden;
      transition: border-color 0.3s;
      flex-shrink: 0;
    }

    /* 正在播放的卡片高亮 */
    .player-card.active {
      border-color: rgba(255,255,255,0.5);
      box-shadow: 0 24px 80px rgba(0,0,0,0.6), 0 0 30px rgba(255,255,255,0.08);
    }

    /* ===== 封面区 ===== */
    .cover-area {
      width: 100%;
      aspect-ratio: 3 / 2;
      position: relative;
      overflow: hidden;
    }
    .cover-area img {
      width: 100%; height: 100%; object-fit: cover;
      display: block;
      transition: transform 0.6s ease;
    }
    .player-card:hover .cover-area img {
      transform: scale(1.03);
    }

    /* ===== 控制区 ===== */
    .controls {
      padding: 12px 16px 16px;
      background: rgba(10,10,14,0.55);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-top: 1px solid rgba(255,255,255,0.04);
    }

    /* ===== 歌曲信息 ===== */
    .song-info {
      margin-bottom: 10px;
      text-align: left;
    }
    .song-title {
      font-size: 0.8rem;
      font-weight: 600;
      color: #fff;
      line-height: 1.4;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .song-artist {
      font-size: 0.68rem;
      color: rgba(255,255,255,0.5);
      margin-top: 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ===== 进度条 ===== */
    .progress-bar {
      width: 100%;
      height: 2px;
      border-radius: 2px;
      background: rgba(255,255,255,0.1);
      cursor: pointer;
      margin-bottom: 8px;
      position: relative;
    }
    .progress-fill {
      height: 100%;
      border-radius: 2px;
      background: #fff;
      width: 0%;
      transition: width 0.3s linear;
      position: relative;
    }
    .progress-fill::after {
      content: '';
      position: absolute; right: -3px; top: -2.5px;
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #fff;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .progress-bar:hover .progress-fill::after {
      opacity: 1;
    }

    .time-row {
      display: flex; justify-content: space-between;
      font-size: 0.7rem; color: rgba(255,255,255,0.3);
      margin-top: 6px;
    }

    /* ===== 底部播放按钮 ===== */
    .play-row {
      display: flex;
      align-items: center;
      justify-content: center;
      padding-top: 10px;
      position: relative;
    }

    /* 音量固定在底部右侧 */
    .play-row .vol-wrap {
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .btn {
      background: none; border: none; color: rgba(255,255,255,0.55);
      cursor: pointer; padding: 6px;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s;
      border-radius: 50%;
    }
    .btn:hover { color: #fff; }

    .btn-vol {
      margin-right: -6px;
    }

    .vol-slider-wrap {
      position: absolute;
      bottom: 100%;
      left: 50%;
      transform: translateX(-50%) scaleY(0);
      transform-origin: bottom center;
      transition: transform 0.2s ease;
      padding-bottom: 8px;
      z-index: 10;
      opacity: 0;
      pointer-events: none;
    }
    .vol-slider-wrap.open {
      transform: translateX(-50%) scaleY(1);
      opacity: 1;
      pointer-events: auto;
    }
    .vol-slider {
      -webkit-appearance: none; appearance: none;
      width: 3px; height: 50px;
      border-radius: 2px;
      background: rgba(255,255,255,0.15);
      outline: none; cursor: pointer;
      writing-mode: vertical-lr;
      direction: rtl;
    }
    .vol-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: #fff;
      cursor: pointer;
    }

    .btn-play {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(255,255,255,0.12);
      color: #fff;
    }
    .btn-play:hover {
      background: rgba(255,255,255,0.2);
      color: #fff;
    }
    .btn-play svg {
      width: 16px; height: 16px;
      margin-left: 2px;
    }
    .btn-play.playing svg {
      margin-left: 0;
    }

    /* ===== 响应式 ===== */
    @media (max-width: 480px) {
      .cards-wrapper {
        gap: 12px;
      }
      .player-card { width: calc(25vw - 12px); max-width: 180px; }
      .controls { padding: 10px 14px 14px; }
    }
  </style>
</head>
