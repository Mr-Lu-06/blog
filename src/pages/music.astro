  <script is:inline>
    (function() {
      var playlist = [
        { title: '富士山下', artist: '陈奕迅', src: '/music/富士山下 - 陈奕迅.mp3', cover: '/images/fushishanxia.jpg' },
        { title: '孤雏', artist: 'AGA', src: '/music/孤雏 - AGA.mp3', cover: '/images/guchu.jpg' },
        { title: '十面埋伏', artist: '陈奕迅', src: '/music/十面埋伏 - 陈奕迅.mp3', cover: '/images/shimianmaifu.jpg' },
        { title: '戒不掉（原声版）', artist: '欧阳耀莹', src: '/music/戒不掉（原声版） - 欧阳耀莹.mp3', cover: '/images/jiebuniao.jpg' },
      ];

      var audio = new Audio();
      var currentIdx = -1;
      var isPlaying = false;

      // 获取所有卡片的 DOM
      var cards = document.querySelectorAll('.player-card');

      // 每张卡片关联的 DOM 引用
      var cardData = {};

      cards.forEach(function(card) {
        var idx = parseInt(card.dataset.card);
        var data = {
          el: card,
          coverImg: card.querySelector('.cover-img'),
          coverPlaceholder: card.querySelector('.cover-placeholder'),
          songTitle: card.querySelector('.song-title'),
          songArtist: card.querySelector('.song-artist'),
          btnPlay: card.querySelector('.btn-play'),
          progressFill: card.querySelector('.progress-fill'),
          timeCurrent: card.querySelector('.time-current'),
          timeTotal: card.querySelector('.time-total'),
          progressBar: card.querySelector('.progress-bar'),
          volSlider: card.querySelector('.vol-slider'),
          volWrap: card.querySelector('.vol-slider-wrap'),
          volIcon: card.querySelector('.vol-icon'),
          volBtn: card.querySelector('.btn-vol'),
          volArea: card.querySelector('.vol-wrap'),
        };
        data.songIdx = idx; // 每个卡片默认播放不同的歌
        cardData[idx] = data;

        // 加载对应歌曲信息（不开始播放）
        loadSongToCard(idx, data.songIdx);

        // 点击播放按钮
        data.btnPlay.addEventListener('click', function(e) {
          e.stopPropagation();
          playOnCard(idx);
        });

        // 进度条点击
        data.progressBar.addEventListener('click', function(e) {
          e.stopPropagation();
          if (currentIdx !== data.songIdx) return;
          if (!audio.duration) return;
          var rect = this.getBoundingClientRect();
          var pct = (e.clientX - rect.left) / rect.width;
          audio.currentTime = pct * audio.duration;
        });

        // 音量滑块
        var sliderOpen = false;
        data.volBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          sliderOpen = !sliderOpen;
          data.volWrap.classList.toggle('open', sliderOpen);
        });
        data.volArea.addEventListener('click', function(e) { e.stopPropagation(); });

        data.volSlider.addEventListener('input', function() {
          audio.volume = parseFloat(this.value);
          updateVolIcon(data);
        });
      });

      // 点击全局收起音量
      document.addEventListener('click', function() {
        for (var k in cardData) {
          cardData[k].volWrap.classList.remove('open');
        }
      });

      function loadSongToCard(cardIdx, songIdx) {
        var data = cardData[cardIdx];
        var song = playlist[songIdx];
        data.songTitle.textContent = song.title;
        data.songArtist.textContent = song.artist;
        if (song.cover) {
          data.coverImg.src = song.cover;
          data.coverImg.style.display = 'block';
          data.coverPlaceholder.style.display = 'none';
        } else {
          data.coverImg.style.display = 'none';
          data.coverPlaceholder.style.display = 'flex';
        }
      }

      function playOnCard(cardIdx) {
        var data = cardData[cardIdx];
        var songIdx = data.songIdx;

        if (currentIdx === songIdx) {
          // 正在播这首歌 → 切换暂停/播放
          if (isPlaying) {
            audio.pause();
            isPlaying = false;
            data.btnPlay.classList.remove('playing');
            data.btnPlay.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="8 5 19 12 8 19 8 5"/></svg>';
          } else {
            audio.play().catch(function(){});
            isPlaying = true;
            data.btnPlay.classList.add('playing');
            data.btnPlay.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';
          }
          return;
        }

        // 切换歌曲
        currentIdx = songIdx;
        audio.src = playlist[songIdx].src;
        audio.play().catch(function(){});
        isPlaying = true;

        // 更新所有卡片状态
        updateAllCardStates();
      }

      function updateAllCardStates() {
        for (var k in cardData) {
          var data = cardData[k];
          var active = (data.songIdx === currentIdx);
          data.el.classList.toggle('active', active);
          if (active && isPlaying) {
            data.btnPlay.classList.add('playing');
            data.btnPlay.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';
          } else {
            data.btnPlay.classList.remove('playing');
            data.btnPlay.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="8 5 19 12 8 19 8 5"/></svg>';
          }
        }
      }

      function updateVolIcon(data) {
        var v = audio.volume;
        data.volIcon.innerHTML = v === 0
          ? '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>'
          : v < 0.3
            ? '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>'
            : '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>';
      }

      audio.volume = 0.5;

      // 自动下一曲
      audio.addEventListener('ended', function() {
        currentIdx = (currentIdx + 1) % playlist.length;
        audio.src = playlist[currentIdx].src;
        audio.play().catch(function(){});
        isPlaying = true;
        updateAllCardStates();
      });

      // 进度更新
      audio.addEventListener('timeupdate', function() {
        if (!audio.duration) return;
        var pct = (audio.currentTime / audio.duration) * 100;
        var t = formatTime(audio.currentTime);
        for (var k in cardData) {
          var d = cardData[k];
          if (d.songIdx === currentIdx) {
            d.progressFill.style.width = pct + '%';
            d.timeCurrent.textContent = t;
          }
        }
      });

      audio.addEventListener('loadedmetadata', function() {
        var total = formatTime(audio.duration);
        for (var k in cardData) {
          var d = cardData[k];
          if (d.songIdx === currentIdx) {
            d.timeTotal.textContent = total;
          }
        }
      });

      function formatTime(t) {
        var m = Math.floor(t / 60);
        var s = Math.floor(t % 60);
        return m + ':' + (s < 10 ? '0' : '') + s;
      }

      // 默认加载（卡片0→第1首，卡片1→第2首，卡片2→第3首，卡片3→第4首）
      loadSongToCard(0, 0);
      loadSongToCard(1, 1);
      loadSongToCard(2, 2);
      loadSongToCard(3, 3);
      // 默认播放卡片0
      playOnCard(0);
    })();
  </script>

  <!-- 拖拽 + 边界淡入淡出 + 焦点缩放 -->
  <script is:inline>
    (function() {
      var wrapper = document.getElementById('cards-wrapper');
      if (!wrapper) return;

      var isDragging = false;
      var startX = 0, startY = 0;
      var rawX = 0, rawY = 0;
      var moved = false;

      function visualPos(rx, ry) {
        var sw = window.innerWidth, sh = window.innerHeight;
        var hw = sw / 2, hh = sh / 2;
        return {
          x: ((rx + hw) % sw + sw) % sw - hw,
          y: ((ry + hh) % sh + sh) % sh - hh,
        };
      }

      function calcOpacity(vx, vy) {
        var sw = window.innerWidth, sh = window.innerHeight;
        var hw = sw / 2, hh = sh / 2;
        var nx = Math.abs(vx) / hw;
        var ny = Math.abs(vy) / hh;
        var dist = Math.max(nx, ny);
        var fadeStart = 0.55;
        if (dist <= fadeStart) return '1';
        return Math.max(0, 1 - (dist - fadeStart) / (1 - fadeStart)) + '';
      }

      function calcScale(vx, vy) {
        var sw = window.innerWidth, sh = window.innerHeight;
        var hw = sw / 2, hh = sh / 2;
        var nx = Math.abs(vx) / hw;
        var ny = Math.abs(vy) / hh;
        var dist = Math.max(nx, ny);
        var scaleStart = 0.3;
        if (dist <= scaleStart) return '1.15';
        var s = 1.15 - (dist - scaleStart) / (1 - scaleStart) * 0.4;
        return Math.max(0.75, s) + '';
      }

      function updateWrapper(vp) {
        var opacity = calcOpacity(vp.x, vp.y);
        var scale = calcScale(vp.x, vp.y);
        wrapper.style.transform = 'translateX(' + vp.x + 'px) translateY(' + vp.y + 'px) scale(' + scale + ')';
        wrapper.style.opacity = opacity;
      }

      // ---- 鼠标 ----
      document.addEventListener('mousedown', function(e) {
        if (e.target.closest('.player-card') || e.target.closest('.close-btn')) return;
        isDragging = true;
        moved = false;
        startX = e.clientX;
        startY = e.clientY;
        wrapper.style.transition = 'none';
      });

      document.addEventListener('mousemove', function(e) {
        if (!isDragging) return;
        var rx = e.clientX - startX + rawX;
        var ry = e.clientY - startY + rawY;
        if (Math.abs(rx - rawX) > 3 || Math.abs(ry - rawY) > 3) moved = true;
        updateWrapper(visualPos(rx, ry));
      });

      document.addEventListener('mouseup', function() {
        if (!isDragging) return;
        isDragging = false;
        if (!moved) {
          wrapper.style.transform = '';
          wrapper.style.opacity = '';
          wrapper.style.transition = '';
          return;
        }
        var t = wrapper.style.transform;
        var m = t.match(/translateX\(([-\d.]+)px\)\s*translateY\(([-\d.]+)px\)/);
        if (m) {
          var vx = parseFloat(m[1]) || 0;
          var vy = parseFloat(m[2]) || 0;
          var sw = window.innerWidth, sh = window.innerHeight;
          var kx = Math.round((rawX - vx) / sw);
          var ky = Math.round((rawY - vy) / sh);
          rawX = vx + kx * sw;
          rawY = vy + ky * sh;
        }
        wrapper.style.transition = '';
      });

      // ---- 触摸 ----
      document.addEventListener('touchstart', function(e) {
        if (e.target.closest('.player-card') || e.target.closest('.close-btn')) return;
        isDragging = true;
        moved = false;
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        wrapper.style.transition = 'none';
      });

      document.addEventListener('touchmove', function(e) {
        if (!isDragging) return;
        var rx = e.touches[0].clientX - startX + rawX;
        var ry = e.touches[0].clientY - startY + rawY;
        if (Math.abs(rx - rawX) > 3 || Math.abs(ry - rawY) > 3) moved = true;
        updateWrapper(visualPos(rx, ry));
      }, { passive: true });

      document.addEventListener('touchend', function() {
        if (!isDragging) return;
        isDragging = false;
        if (!moved) {
          wrapper.style.transform = '';
          wrapper.style.opacity = '';
          wrapper.style.transition = '';
          return;
        }
        var t = wrapper.style.transform;
        var m = t.match(/translateX\(([-\d.]+)px\)\s*translateY\(([-\d.]+)px\)/);
        if (m) {
          var vx = parseFloat(m[1]) || 0;
          var vy = parseFloat(m[2]) || 0;
          var sw = window.innerWidth, sh = window.innerHeight;
          var kx = Math.round((rawX - vx) / sw);
          var ky = Math.round((rawY - vy) / sh);
          rawX = vx + kx * sw;
          rawY = vy + ky * sh;
        }
        wrapper.style.transition = '';
      });
    })();
  </script>
</body>
</html>
