---
// 音乐馆 - 清爽卡片风格
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>音乐 — 我的小窝</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: system-ui, 'PingFang SC', sans-serif;
      background: #f5f3f0;
      color: #333;
    }

    /* ===== 导航 ===== */
    .navbar {
      position: sticky; top: 0; z-index: 40;
      background: rgba(245,243,240,0.85); backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .navbar-inner {
      max-width: 1000px; margin: 0 auto; padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
      height: 56px; gap: 16px;
    }
    .navbar-brand { font-size: 1.1rem; font-weight: 700; color: #333; text-decoration: none; }
    .navbar-links { display: flex; gap: 4px; }
    .nav-link {
      padding: 6px 16px; border-radius: 8px; color: #888; text-decoration: none;
      font-size: 0.85rem; font-weight: 500; transition: all 0.2s;
    }
    .nav-link:hover { color: #333; background: rgba(0,0,0,0.04); }
    .nav-link.active { color: #e85d75; background: rgba(232,93,117,0.08); }
    .nav-back {
      color: #999; text-decoration: none; font-size: 0.85rem;
      display: flex; align-items: center; gap: 4px;
    }
    .nav-back:hover { color: #333; }

    /* ===== 内容 ===== */
    .music-content {
      max-width: 1000px; margin: 0 auto; padding: 40px 24px 80px;
    }
    .music-header {
      text-align: center; margin-bottom: 40px;
    }
    .music-header h1 { font-size: 1.8rem; font-weight: 800; color: #333; margin-bottom: 6px; }
    .music-header p { color: #999; font-size: 0.9rem; }

    /* ===== 卡片网格 ===== */
    .track-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 24px;
    }
    .track-card {
      background: #fff; border-radius: 14px; overflow: hidden;
      cursor: pointer; transition: all 0.3s;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      display: flex; flex-direction: column;
    }
    .track-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 28px rgba(0,0,0,0.1);
    }
    .track-card.playing {
      box-shadow: 0 0 0 2px #e85d75, 0 8px 28px rgba(232,93,117,0.15);
    }

    /* ===== 封面图 ===== */
    .track-cover {
      width: 100%; aspect-ratio: 1;
      overflow: hidden; position: relative;
      background: linear-gradient(135deg, #fce4ec, #f3e5f5);
      flex-shrink: 0;
    }
    .track-cover img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform 0.4s;
    }
    .track-card:hover .track-cover img { transform: scale(1.06); }
    .track-cover-placeholder {
      width: 100%; height: 100%; display: flex;
      align-items: center; justify-content: center;
      font-size: 2.8rem; color: rgba(0,0,0,0.08);
    }
    .track-cover-badge {
      position: absolute; top: 8px; right: 8px;
      padding: 3px 10px; border-radius: 10px;
      background: rgba(0,0,0,0.45); color: #fff;
      font-size: 0.7rem; font-weight: 600; backdrop-filter: blur(8px);
      opacity: 0; transition: opacity 0.3s;
    }
    .track-card:hover .track-cover-badge,
    .track-card.playing .track-cover-badge { opacity: 1; }

    /* ===== 文字信息 ===== */
    .track-info {
      padding: 12px 14px; flex: 1;
      display: flex; flex-direction: column; gap: 2px;
    }
    .track-title {
      font-size: 0.88rem; font-weight: 600; color: #333;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .track-artist {
      font-size: 0.78rem; color: #aaa;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    /* ===== 手机 ===== */
    @media (max-width: 640px) {
      .track-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
      .music-content { padding: 24px 16px 60px; }
      .music-header h1 { font-size: 1.4rem; }
    }
  </style>
</head>
<body>
  <!-- 导航 -->
  <header class="navbar">
    <div class="navbar-inner">
      <a href="/" class="navbar-brand">我的小窝</a>
      <div class="navbar-links">
        <a href="/" class="nav-link">日记</a>
        <a href="/music" class="nav-link active">音乐</a>
        <a href="/gallery" class="nav-link">相册</a>
      </div>
      <a href="/" class="nav-back">← 返回</a>
    </div>
  </header>

  <!-- 内容 -->
  <main class="music-content">
    <div class="music-header">
      <h1>音乐馆</h1>
      <p>共 4 首</p>
    </div>

    <div class="track-grid" id="track-grid"></div>
  </main>

  <audio id="audio-player" style="display:none;"></audio>

  <script is:inline>
    (function() {
      var playlist = [
        { title: '富士山下', artist: '陈奕迅', src: '/music/富士山下 - 陈奕迅.mp3', cover: '/images/fushishanxia.jpg' },
        { title: '孤雏', artist: 'AGA', src: '/music/孤雏 - AGA.mp3', cover: '/images/guchu.jpg' },
        { title: '十面埋伏', artist: '陈奕迅', src: '/music/十面埋伏 - 陈奕迅.mp3', cover: '/images/shimianmaifu.jpg' },
        { title: '戒不掉（原声版）', artist: '欧阳耀莹', src: '/music/戒不掉（原声版） - 欧阳耀莹.mp3', cover: '/images/jiebuniao.jpg' },
      ];

      var grid = document.getElementById('track-grid');
      var audio = document.getElementById('audio-player');
      var currentIdx = -1;

      function escapeHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }

      playlist.forEach(function(song, i) {
        var card = document.createElement('div');
        card.className = 'track-card';
        card.setAttribute('data-idx', i);

        card.innerHTML =
          '<div class="track-cover">' +
            '<div class="track-cover-badge">♪ 播放</div>' +
            (song.cover
              ? '<img src="' + song.cover + '" alt="' + escapeHtml(song.title) + '" />'
              : '<div class="track-cover-placeholder">♪</div>'
            ) +
          '</div>' +
          '<div class="track-info">' +
            '<div class="track-title">' + escapeHtml(song.title) + '</div>' +
            '<div class="track-artist">' + escapeHtml(song.artist) + '</div>' +
          '</div>';

        card.addEventListener('click', function() {
          if (currentIdx === i) {
            if (audio.paused) { audio.play(); } else { audio.pause(); }
            return;
          }
          var old = grid.querySelector('.track-card.playing');
          if (old) old.classList.remove('playing');
          currentIdx = i;
          audio.src = playlist[i].src;
          audio.play().catch(function() {});
          card.classList.add('playing');
        });

        grid.appendChild(card);
      });

      audio.addEventListener('ended', function() {
        var old = grid.querySelector('.track-card.playing');
        if (old) old.classList.remove('playing');
        currentIdx = (currentIdx + 1) % playlist.length;
        audio.src = playlist[currentIdx].src;
        audio.play().catch(function() {});
        var cards = grid.querySelectorAll('.track-card');
        if (cards[currentIdx]) cards[currentIdx].classList.add('playing');
      });
    })();
  </script>
</body>
</html>
