<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>音乐</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: system-ui, 'PingFang SC', sans-serif; background: #f5f3f0; }
    .close-btn {
      position: fixed; top: 20px; right: 24px; z-index: 100;
      width: 40px; height: 40px; border-radius: 50%;
      background: rgba(0,0,0,0.04); border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; color: #999; transition: all 0.2s;
      text-decoration: none;
    }
    .close-btn:hover { background: rgba(0,0,0,0.08); color: #333; }
  </style>
</head>
<body>
  <a href="/" class="close-btn" title="返回首页">×</a>
</body>
</html>
