<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>音乐</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: system-ui, 'PingFang SC', sans-serif;
      min-height: 100vh;
      background: #0a0a0a;
    }
    .bg {
      position: fixed; inset: 0; z-index: -1;
    }
    .bg img {
      width: 100%; height: 100%; object-fit: cover;
    }
    .bg-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom,
        rgba(0,0,0,0.15) 0%,
        rgba(0,0,0,0.45) 100%
      );
    }
    .close-btn {
      position: fixed; top: 20px; right: 24px; z-index: 100;
      width: 40px; height: 40px; border-radius: 50%;
      background: rgba(0,0,0,0.35); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.1);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; color: rgba(255,255,255,0.7);
      transition: all 0.2s;
      text-decoration: none;
    }
    .close-btn:hover { background: rgba(0,0,0,0.5); color: #fff; }
  </style>
</head>
<body>
  <div class="bg">
    <img src="/images/music-bg.jpg" alt="" />
    <div class="bg-overlay"></div>
  </div>
  <a href="/" class="close-btn" title="返回首页">×</a>
</body>
</html>
